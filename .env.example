# .env.example — copy to .env and fill in your keys
# Never commit .env

# ── Required ──────────────────────────────────────────────────────────────

# Nebius API key — used for both LLMs (Gemma via bank graph, MiniMax via manager graph)
NEBIUS_API_KEY=your-nebius-api-key-here

# Speechmatics — TTS (all three voices) and optional ASR round-trip
SPEECHMATICS_API_KEY=your-speechmatics-api-key-here

# ── Optional ──────────────────────────────────────────────────────────────

# Set to "true" to enable the TTS → ASR round-trip (realistic speech loop)
# When false (default), the raw LLM text is sent to the bank graph directly
ENABLE_SPEECHMATICS_ASR=false

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=WARNING